<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Barra superior roja con botón volver y título -->
    <LinearLayout
        android:id="@+id/barraRojaEquipo"
        android:layout_width="match_parent"
        android:layout_height="116dp"
        android:background="#CC0000"
        android:paddingStart="8dp"
        android:paddingTop="55dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Botón para volver a la pantalla anterior -->
        <ImageButton
            android:id="@+id/btnVolverEquipo"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"
            android:padding="8dp"
            android:contentDescription="Volver" />

        <!-- Título de la pantalla -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mis Equipos"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- Espaciador para centrar el título -->
        <View
            android:layout_width="42dp"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Botón para crear un equipo nuevo -->
    <Button
        android:id="@+id/btnNuevoEquipo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Nuevo Equipo"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#CC0000"
        android:layout_margin="16dp"
        android:padding="12dp"/>

    <!-- Mensaje que aparece cuando no hay equipos creados todavía -->
    <TextView
        android:id="@+id/tvSinEquipos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No tienes equipos creados aún"
        android:textColor="#757575"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- Lista de equipos creados por el usuario -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerEquipos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"/>

</LinearLayout>