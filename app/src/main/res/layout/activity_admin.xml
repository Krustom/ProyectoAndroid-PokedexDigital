<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Barra roja superior con botón volver -->
    <LinearLayout
        android:id="@+id/barraRojaAdmin"
        android:layout_width="match_parent"
        android:layout_height="116dp"
        android:background="#CC0000"
        android:paddingStart="8dp"
        android:paddingTop="55dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
<!-- Botón para volver a la pantalla anterior -->
        <ImageButton
            android:id="@+id/btnVolverAdmin"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"
            android:padding="8dp"
            android:contentDescription="Volver"/>
<!-- Título -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Panel de Administración"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"/>
<!-- bottón para cerrar sesión -->
        <ImageButton
            android:id="@+id/btnLogout"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cerrar sesión"
            android:src="@drawable/account"
            app:tint="#FFFFFF" />

    </LinearLayout>

    <!-- Contenido desplazable -->

    <!-- RecyclerView fuera del ScrollView para scroll independiente -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Título sección estadísticas -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp"
                android:text="📊 Estadísticas generales"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Tarjetas de estadísticas en fila -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Tarjeta usuarios -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤 Usuarios registrados"
                        android:textColor="#757575"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvNumUsuarios"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#CC0000"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Tarjeta equipos -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚔️ Equipos creados"
                        android:textColor="#757575"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvNumEquipos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#CC0000"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:background="#DDDDDD" />

            <!-- Título lista pokémon -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="🔴 Lista de Pokémon (primeros 151)"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Botón para cerrar sesión -->

        </LinearLayout>

    </ScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAdminPokemon"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>