<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:layout_width="420dp"
        android:layout_height="420dp"
        android:layout_gravity="center"
        android:src="@drawable/pokeball"
        android:alpha="0.10"
        android:scaleType="fitCenter"/>

    <TextView
        android:id="@+id/btnVolverLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="←"
        android:textColor="#212121"
        android:textSize="40sp"
        android:padding="16dp"
        android:layout_gravity="top|start"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crear Cuenta"
            android:textColor="#CC0000"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Únete a la Pokédex Digital"
            android:textColor="#757575"
            android:textSize="14sp"
            android:layout_marginBottom="40dp"/>

        <!-- Campo Email -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Correo electrónico"
            android:inputType="textEmailAddress"
            android:textColor="#212121"
            android:textColorHint="#757575"
            android:background="#F5F5F5"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Campo Contraseña con ojo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:textColor="#212121"
                android:textColorHint="#757575"
                android:background="@null"
                android:paddingStart="16dp"/>

            <TextView
                android:id="@+id/btnMostrarPassword"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="👁"
                android:textSize="18sp"
                android:gravity="center"
                android:paddingEnd="12dp"/>
        </LinearLayout>

        <!-- Campo Confirmar Contraseña con ojo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/etConfirmarPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Confirmar contraseña"
                android:inputType="textPassword"
                android:textColor="#212121"
                android:textColorHint="#757575"
                android:background="@null"
                android:paddingStart="16dp"/>

            <TextView
                android:id="@+id/btnMostrarConfirmar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="👁"
                android:textSize="18sp"
                android:gravity="center"
                android:paddingEnd="12dp"/>
        </LinearLayout>

        <!-- Botón Registro -->
        <Button
            android:id="@+id/btnRegistro"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CREAR CUENTA"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#CC0000"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvIrLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Ya tienes cuenta? Inicia sesión"
            android:textColor="#CC0000"
            android:textSize="14sp"
            android:layout_gravity="center"/>

    </LinearLayout>

</FrameLayout>
