<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Barra superior roja con botón volver -->
        <LinearLayout
            android:id="@+id/barraRojaDetalle"
            android:layout_width="match_parent"
            android:layout_height="116dp"
            android:background="#CC0000"
            android:paddingStart="8dp"
            android:paddingTop="55dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Botón para volver a la lista de pokémon -->
            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#FFFFFF"
                android:padding="8dp"
                android:contentDescription="Volver" />

            <!-- Número y nombre del pokémon -->
            <TextView
                android:id="@+id/tvNumeroNombre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <!-- Espaciador para centrar el título -->
            <View
                android:layout_width="42dp"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Imagen del pokémon -->
        <ImageView
            android:id="@+id/ivPokemon"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:scaleType="fitCenter"
            android:contentDescription="Imagen del Pokémon"/>

        <!-- Tipo del pokémon -->
        <TextView
            android:id="@+id/tvTipos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="16sp"
            android:gravity="center"
            android:padding="8dp"/>

        <!-- Descripción de la Pokédex -->
        <TextView
            android:id="@+id/tvDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#424242"
            android:textSize="14sp"
            android:padding="16dp"
            android:lineSpacingMultiplier="1.3"/>

        <!-- Estadísticas base del pokémon -->
        <TextView
            android:id="@+id/tvEstadisticas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="14sp"
            android:padding="16dp"
            android:lineSpacingMultiplier="1.4"/>

        <!-- Título de la sección de evoluciones -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadena de evolución"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingBottom="8dp"/>

        <!-- Contenedor donde dibujo la cadena de evolución -->
        <LinearLayout
            android:id="@+id/layoutEvoluciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"/>

        <!-- Botón para añadir o quitar de favoritos -->
        <Button
            android:id="@+id/btnFavorito"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="♡ Añadir a favoritos"
            android:textColor="#FFFFFF"
            android:backgroundTint="#CC0000"
            android:layout_margin="16dp"
            android:padding="12dp"/>

    </LinearLayout>

</ScrollView>